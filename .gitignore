#standard gitignore file for a ROS2 package, it ignores the build, install and log folders generated by colcon,
#as well as various build and editor artifacts that are not relevant to the project.

# colcon/CMake output
build/
install/
log/

# various build/editor artifacts
*.pyc
*.iml
*.swp
.project
.pydevproject
.DS_Store
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
__pycache__/
.cache/

# Jupyter Notebook
.ipynb_checkpoints/

# Virtual Environments
venv/
env/
.env/
